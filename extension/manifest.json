{
  "manifest_version": 3,
  "name": "学伴 StudyBuddy",
  "version": "0.1.0",
  "description": "你的大学 AI 伴侣 — 自动收集学习平台数据，AI 个性化辅导",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.chaoxing.com/*",
    "*://*.zhihuishu.com/*",
    "*://*.xuexi.cn/*",
    "*://*.xuexiqiangguo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chaoxing.com/*",
        "*://*.zhihuishu.com/*",
        "*://*.xuexi.cn/*",
        "*://*.xuexiqiangguo.com/*"
      ],
      "js": ["platforms/registry.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "学伴 - 查看抓取状态"
  }
}
